```gitignore
# Compiled and binary files
*.pyc
__pycache__/
*.class
*.o
*.exe
*.dll
*.so
*.a
*.obj
*.out

# Dependencies
node_modules/
venv/
.venv/
.env
.env.local
*.env.*

# Build artifacts
dist/
build/
target/

# Editor/IDE files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# Logs
*.log

# Coverage
coverage/
htmlcov/
.coverage

# Python specific
*.pyc
__pycache__/
.pytest_cache/
.mypy_cache/

# System files
.DS_Store
Thumbs.db
```